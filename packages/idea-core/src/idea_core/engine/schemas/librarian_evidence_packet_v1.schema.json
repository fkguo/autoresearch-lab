{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "librarian_evidence_packet_v1.schema.json",
  "title": "Librarian Evidence Packet v1",
  "type": "object",
  "required": [
    "packet_type",
    "packet_schema_version",
    "relevance_policy",
    "packet_id",
    "campaign_id",
    "step_id",
    "tick",
    "island_id",
    "operator_id",
    "operator_family",
    "generated_by_role",
    "recipes",
    "evidence_items",
    "retrieval_timestamp",
    "generated_at"
  ],
  "properties": {
    "packet_type": { "const": "librarian_evidence_packet_v1" },
    "packet_schema_version": { "const": 1 },
    "relevance_policy": { "const": "template_prior_v1" },
    "packet_id": { "type": "string", "minLength": 1 },
    "campaign_id": { "type": "string", "format": "uuid" },
    "step_id": { "type": "string", "format": "uuid" },
    "tick": { "type": "integer", "minimum": 1 },
    "island_id": { "type": "string", "minLength": 1 },
    "operator_id": { "type": "string", "minLength": 1 },
    "operator_family": { "type": "string", "minLength": 1 },
    "generated_by_role": { "const": "Librarian" },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "recipe_id",
          "provider",
          "query_template",
          "query",
          "api_source",
          "api_query",
          "raw_response_hash",
          "hits"
        ],
        "properties": {
          "recipe_id": { "type": "string", "minLength": 1 },
          "provider": { "enum": ["INSPIRE", "PDG"] },
          "query_template": { "type": "string", "minLength": 1 },
          "query": { "type": "string", "minLength": 1 },
          "api_source": { "enum": ["INSPIRE", "PDG"] },
          "api_query": { "type": "string", "minLength": 1 },
          "raw_response_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "hits": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["uri", "summary", "summary_source", "relevance"],
              "properties": {
                "uri": { "type": "string", "format": "uri" },
                "summary": { "type": "string", "minLength": 1 },
                "summary_source": { "const": "template" },
                "relevance": { "type": "number", "minimum": 0, "maximum": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["provider", "recipe_id", "uri", "summary", "relevance"],
        "properties": {
          "provider": { "enum": ["INSPIRE", "PDG"] },
          "recipe_id": { "type": "string", "minLength": 1 },
          "uri": { "type": "string", "format": "uri" },
          "summary": { "type": "string", "minLength": 1 },
          "relevance": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "retrieval_timestamp": { "type": "string", "format": "date-time" },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
