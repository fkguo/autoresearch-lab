{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "milestone_gate_v1.schema.json",
  "title": "MilestoneGate v1",
  "description": "Machine-checkable milestone completion gate for the idea campaign control-plane workflow.",
  "type": "object",
  "required": [
    "milestone_id",
    "generated_at",
    "review",
    "scope",
    "literature",
    "novelty",
    "core_loop",
    "gate_status"
  ],
  "properties": {
    "milestone_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "campaign_id": {
      "type": "string",
      "format": "uuid"
    },
    "review": {
      "type": "object",
      "required": [
        "reviewer_a",
        "reviewer_b",
        "both_ready",
        "round",
        "fallback_mode"
      ],
      "properties": {
        "reviewer_a": {
          "type": "object",
          "required": [
            "model",
            "verdict",
            "timestamp"
          ],
          "properties": {
            "model": { "const": "opus" },
            "verdict": { "enum": ["READY", "NOT_READY"] },
            "timestamp": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "reviewer_b": {
          "type": "object",
          "required": [
            "requested_model",
            "resolved_model",
            "fallback_reason",
            "verdict",
            "timestamp"
          ],
          "properties": {
            "requested_model": { "const": "gemini-3-pro-preview" },
            "resolved_model": { "const": "gemini-3-pro-preview" },
            "fallback_reason": { "type": "null" },
            "verdict": { "enum": ["READY", "NOT_READY"] },
            "timestamp": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "both_ready": { "const": true },
        "round": { "type": "integer", "minimum": 1 },
        "fallback_mode": { "const": "ask" }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "scope",
        "non_citation_required",
        "non_citation_marker"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "ecosystem_validation",
            "preliminary_physics",
            "publication_ready"
          ]
        },
        "non_citation_required": { "type": "boolean" },
        "non_citation_marker": { "const": "NOT_FOR_CITATION" },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scope": {
                "enum": ["ecosystem_validation", "preliminary_physics"]
              }
            },
            "required": ["scope"]
          },
          "then": {
            "properties": {
              "non_citation_required": { "const": true }
            },
            "required": ["non_citation_required"]
          }
        },
        {
          "if": {
            "properties": {
              "scope": { "const": "publication_ready" }
            },
            "required": ["scope"]
          },
          "then": {
            "properties": {
              "non_citation_required": { "const": false }
            },
            "required": ["non_citation_required"]
          }
        }
      ],
      "additionalProperties": false
    },
    "literature": {
      "type": "object",
      "required": [
        "new_retrieval_count",
        "evidence_artifact_ref"
      ],
      "properties": {
        "new_retrieval_count": { "type": "integer", "minimum": 5 },
        "evidence_artifact_ref": {
          "type": "string",
          "pattern": "^(artifacts/|file://).+\\.json$"
        }
      },
      "additionalProperties": false
    },
    "novelty": {
      "type": "object",
      "required": [
        "all_review_candidates_novel",
        "artifact_paths",
        "rejected_count"
      ],
      "properties": {
        "all_review_candidates_novel": { "const": true },
        "artifact_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(artifacts/ideas/[^/]+/novelty_delta[^/]*\\.json|file://.+novelty_delta[^/]*\\.json)$"
          }
        },
        "rejected_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "core_loop": {
      "type": "object",
      "required": [
        "steps_executed",
        "artifact_refs",
        "failed_approach_count",
        "execution_complete"
      ],
      "properties": {
        "steps_executed": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "artifact_refs": {
          "type": "object",
          "required": [
            "idea_candidates_artifact_ref",
            "idea_scorecards_artifact_ref",
            "ranking_result_artifact_ref",
            "idea_selection_artifact_ref",
            "failed_approach_artifact_ref"
          ],
          "properties": {
            "idea_candidates_artifact_ref": {
              "type": "string",
              "pattern": "^(artifacts/|file://).+\\.jsonl?$"
            },
            "idea_scorecards_artifact_ref": {
              "type": "string",
              "pattern": "^(artifacts/|file://).+\\.json$"
            },
            "ranking_result_artifact_ref": {
              "type": "string",
              "pattern": "^(artifacts/|file://).+\\.json$"
            },
            "idea_selection_artifact_ref": {
              "type": "string",
              "pattern": "^(artifacts/|file://).+\\.json$"
            },
            "failed_approach_artifact_ref": {
              "type": "string",
              "pattern": "^(artifacts/|file://).+\\.jsonl?$"
            },
            "idea_handoff_c2_artifact_ref": {
              "type": "string",
              "pattern": "^(artifacts/|file://).+\\.json$"
            }
          },
          "additionalProperties": false
        },
        "failed_approach_count": { "type": "integer", "minimum": 1 },
        "execution_complete": { "const": true }
      },
      "allOf": [
        {
          "properties": {
            "steps_executed": {
              "contains": { "const": "search.step" }
            }
          }
        },
        {
          "properties": {
            "steps_executed": {
              "contains": { "const": "eval.run" }
            }
          }
        },
        {
          "properties": {
            "steps_executed": {
              "contains": { "const": "rank.compute" }
            }
          }
        },
        {
          "properties": {
            "steps_executed": {
              "contains": { "const": "node.promote" }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "gate_status": { "const": "pass" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "review": {
            "properties": {
              "reviewer_a": {
                "properties": {
                  "verdict": { "const": "READY" }
                }
              },
              "reviewer_b": {
                "properties": {
                  "verdict": { "const": "READY" }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "both_ready": { "const": true }
            },
            "required": ["both_ready"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
