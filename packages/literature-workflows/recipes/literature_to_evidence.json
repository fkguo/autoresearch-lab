{
  "recipe_id": "literature_to_evidence",
  "name": "Literature to Evidence",
  "description": "Search and export a curated paper set, then materialize run-level evidence artifacts for downstream indexing.",
  "entry_tool": "literature_workflows.resolve",
  "steps": [
    {
      "id": "search_export",
      "task_kind": "literature",
      "action": "discover.seed_search",
      "purpose": "Run search and write export artifacts",
      "required_capabilities": [
        "supports_keyword_search"
      ],
      "preferred_providers": [
        "inspire",
        "openalex",
        "arxiv"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "discover"
        ],
        "artifact": "search_export",
        "search_depth_contract": {
          "mode": "deep",
          "pagination_required": true,
          "cursor_or_page_tracking_required": true,
          "continuation_required": true,
          "returned_count_required": true,
          "stop_reason_required": true,
          "coverage_incomplete_status": "coverage_incomplete",
          "candidate_pool_artifact": "search_export_candidates",
          "selection_rationale_required": true,
          "query_expansion_expected": true,
          "citation_expansion_expected": true
        },
        "reading_handoff_contract": {
          "mode": "source_first",
          "source_preference": [
            "arxiv_latex_source",
            "full_text_pdf",
            "available_full_text",
            "metadata_only_not_evidence_ready"
          ],
          "note_upgrade_required": true,
          "expected_artifact": "source_first_reading_notes",
          "locators_required": true,
          "key_equations_required": true,
          "limitations_required": true
        }
      },
      "params": {
        "query": "<query>",
        "run_id": "<run_id>",
        "output_format": "jsonl"
      }
    },
    {
      "id": "build_evidence",
      "task_kind": "literature",
      "action": "materialize.evidence_build",
      "purpose": "Build evidence catalog from selected papers",
      "depends_on": [
        "search_export"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "materialize"
        ],
        "artifact": "build_evidence",
        "project_required": true,
        "run_required": true
      },
      "params": {
        "project_id": "<project_id>",
        "paper_id": "<paper_id>"
      }
    }
  ]
}
