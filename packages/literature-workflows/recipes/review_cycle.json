{
  "recipe_id": "review_cycle",
  "name": "Review Cycle",
  "description": "Run critical analysis, render manuscript latex, and export final research assets.",
  "entry_tool": "inspire_critical_analysis",
  "steps": [
    {
      "id": "critical_review",
      "task_kind": "review",
      "tool": "inspire_critical_analysis",
      "purpose": "Generate bounded critical analysis for the target paper",
      "params": {
        "recid": "<recid>"
      }
    },
    {
      "id": "render_latex",
      "task_kind": "draft_update",
      "tool": "hep_render_latex",
      "purpose": "Render section/report draft into latex artifacts",
      "depends_on": [
        "critical_review"
      ],
      "params": {
        "run_id": "<run_id>",
        "draft": {
          "version": 1,
          "sections": []
        }
      }
    },
    {
      "id": "export_project",
      "task_kind": "draft_update",
      "tool": "hep_export_project",
      "purpose": "Export report/bib/research pack artifacts",
      "depends_on": [
        "render_latex"
      ],
      "params": {
        "run_id": "<run_id>"
      }
    }
  ]
}
