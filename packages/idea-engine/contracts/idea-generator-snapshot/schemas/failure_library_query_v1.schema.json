{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "failure_library_query_v1.schema.json",
  "title": "FailureLibraryQuery v1",
  "description": "Project-local query config for the failure library (negative results) to avoid repeating known dead ends.",
  "type": "object",
  "required": ["version", "generated_at_utc", "query", "output_artifact_path"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "query": {
      "type": "object",
      "required": ["tags"],
      "properties": {
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 },
          "description": "Reusable retrieval keys; recommended \"key:value\" strings (e.g., \"method:bootstrap\")."
        },
        "failure_modes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "text": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "max_hits": { "type": "integer", "minimum": 1, "default": 50 },
    "output_artifact_path": {
      "type": "string",
      "pattern": "^artifacts/.*\\.json$",
      "description": "Project-relative output path for FailureLibraryHits. Must live under artifacts/."
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
