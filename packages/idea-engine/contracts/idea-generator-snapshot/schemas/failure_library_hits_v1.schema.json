{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "failure_library_hits_v1.schema.json",
  "title": "FailureLibraryHits v1",
  "description": "Result of running a FailureLibraryQuery against the aggregated failure library index.",
  "type": "object",
  "required": ["version", "generated_at_utc", "query", "index_ref", "hits"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "query": { "$ref": "./failure_library_query_v1.schema.json" },
    "index_ref": {
      "type": "object",
      "required": ["path", "generated_at_utc", "entries_total"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "format": "date-time" },
        "entries_total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "hits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["project_slug", "artifact_relpath", "line_number", "failed_approach"],
        "properties": {
          "project_slug": { "type": "string", "minLength": 1 },
          "artifact_relpath": { "type": "string", "minLength": 1 },
          "line_number": { "type": "integer", "minimum": 1 },
          "failed_approach": { "$ref": "./failed_approach_v1.schema.json" }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
