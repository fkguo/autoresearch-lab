{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "numerics_validation_report_v1.schema.json",
  "title": "NumericsValidationReport v1",
  "description": "Validation evidence for numerical implementation quality and error control.",
  "type": "object",
  "required": [
    "generated_at",
    "scope",
    "non_citation_required",
    "chosen_method",
    "convergence_sweeps",
    "cross_checks",
    "estimated_error",
    "pass_thresholds",
    "failed_checks_count",
    "conclusion"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "enum": [
        "ecosystem_validation",
        "preliminary_physics",
        "publication_ready"
      ]
    },
    "non_citation_required": {
      "type": "boolean"
    },
    "chosen_method": {
      "type": "string",
      "minLength": 1
    },
    "convergence_sweeps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "axis",
          "tested_values",
          "observed_metric",
          "trend"
        ],
        "properties": {
          "axis": {
            "type": "string",
            "minLength": 1
          },
          "tested_values": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "number"
            }
          },
          "observed_metric": {
            "type": "string",
            "minLength": 1
          },
          "trend": {
            "enum": [
              "improving",
              "stable",
              "diverging",
              "inconclusive"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "cross_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "check_type",
          "baseline_method",
          "comparison_method",
          "metric",
          "passed"
        ],
        "properties": {
          "check_type": {
            "enum": [
              "algorithm_swap",
              "implementation_swap",
              "analytic_limit",
              "known_case"
            ]
          },
          "baseline_method": {
            "type": "string",
            "minLength": 1
          },
          "comparison_method": {
            "type": "string",
            "minLength": 1
          },
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "estimated_error": {
      "type": "object",
      "required": [
        "metric",
        "value"
      ],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number",
          "minimum": 0
        },
        "units": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "pass_thresholds": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number"
      }
    },
    "failed_checks_count": {
      "type": "integer",
      "minimum": 0
    },
    "conclusion": {
      "enum": [
        "pass",
        "partial",
        "fail"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "const": "publication_ready"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "non_citation_required": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "enum": [
              "ecosystem_validation",
              "preliminary_physics"
            ]
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "non_citation_required": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "conclusion": {
            "const": "pass"
          }
        },
        "required": [
          "conclusion"
        ]
      },
      "then": {
        "properties": {
          "failed_checks_count": {
            "const": 0
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
