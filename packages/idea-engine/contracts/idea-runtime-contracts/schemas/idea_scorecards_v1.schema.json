{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idea_scorecards_v1.schema.json",
  "title": "IdeaScorecards v1",
  "description": "SSOT artifact: aggregated multi-agent evaluation outputs (scorecards) for a campaign.",
  "$comment": "Stub schema (v0.2): keep dimension IDs stable; per-reviewer payloads may be added later.",
  "type": "object",
  "required": [
    "campaign_id",
    "generated_at",
    "evaluator_config",
    "scorecards"
  ],
  "properties": {
    "campaign_id": {
      "type": "string",
      "format": "uuid"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "evaluator_config": {
      "$ref": "./evaluator_config_v1.schema.json"
    },
    "scorecards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "scores",
          "reviewer_count",
          "status"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "format": "uuid"
          },
          "scores": {
            "type": "object",
            "description": "Per-dimension scores. Keys should match EvaluatorConfig.dimensions.",
            "additionalProperties": {
              "type": "number"
            }
          },
          "reviewer_count": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "enum": [
              "complete",
              "partial",
              "failed"
            ],
            "description": "Completeness marker for scores: complete=usable scores for all intended dimensions; partial=some usable scores but not all; failed=no usable scores (rank.compute MUST ignore when computing observed_keys)."
          },
          "evidence_uris": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "novelty_delta_table": {
            "$ref": "./novelty_delta_table_v1.schema.json"
          },
          "fix_suggestions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "failure_mode",
                "suggested_action",
                "target_field",
                "priority"
              ],
              "properties": {
                "failure_mode": {
                  "enum": [
                    "missing_evidence",
                    "too_similar",
                    "physics_inconsistency",
                    "not_computable",
                    "folklore_overlap",
                    "untestable"
                  ]
                },
                "suggested_action": {
                  "type": "string",
                  "minLength": 1
                },
                "target_field": {
                  "type": "string",
                  "minLength": 1
                },
                "operator_hint": {
                  "type": "string"
                },
                "priority": {
                  "enum": [
                    "critical",
                    "major",
                    "minor"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "failure_modes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Superset of failure modes (may include free-text diagnostics beyond the fix_suggestions enum)."
          },
          "notes": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "failed"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "scores": {
                  "maxProperties": 0
                },
                "failure_modes": {
                  "minItems": 1
                }
              },
              "required": [
                "failure_modes"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "enum": [
                    "complete",
                    "partial"
                  ]
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "scores": {
                  "minProperties": 1
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
