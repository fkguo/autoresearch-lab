{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "computation_feedback_v1.schema.json",
  "title": "ComputationFeedback v1",
  "description": "Private idea-engine mailbox artifact derived from canonical computation_result_v1 for local failure-library and distributor feedback ingestion.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "run_id",
    "campaign_id",
    "node_id",
    "idea_id",
    "source_handoff_uri",
    "computation_result_uri",
    "manifest_ref_uri",
    "produced_artifact_uris",
    "execution_status",
    "feedback_signal",
    "decision_kind",
    "priority_change",
    "prune_candidate",
    "objective_title",
    "summary",
    "finished_at",
    "executor_step_ids"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "minLength": 1 },
    "campaign_id": { "type": "string", "format": "uuid" },
    "node_id": { "type": "string", "format": "uuid" },
    "idea_id": { "type": "string", "format": "uuid" },
    "source_handoff_uri": { "type": "string", "minLength": 1 },
    "computation_result_uri": { "type": "string", "format": "uri" },
    "manifest_ref_uri": { "type": "string", "format": "uri" },
    "produced_artifact_uris": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "execution_status": { "enum": ["completed", "failed"] },
    "feedback_signal": { "enum": ["success", "weak_signal", "failure"] },
    "decision_kind": { "enum": ["capture_finding", "branch_idea", "downgrade_idea", "literature_followup"] },
    "priority_change": { "enum": ["raise", "keep", "lower"] },
    "prune_candidate": { "type": "boolean" },
    "objective_title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "failure_reason": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "finished_at": { "type": "string", "format": "date-time" },
    "executor_step_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
