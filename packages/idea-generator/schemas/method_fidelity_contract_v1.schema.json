{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "method_fidelity_contract_v1.schema.json",
  "title": "MethodFidelityContract v1",
  "description": "Machine-checkable contract for alignment between claimed and implemented methodology.",
  "type": "object",
  "required": [
    "scope",
    "non_citation_required",
    "claimed_methodology",
    "implemented_method_classification",
    "constraints_enforced",
    "disallowed_shortcuts_detected",
    "evidence_pointers"
  ],
  "properties": {
    "scope": {
      "enum": [
        "ecosystem_validation",
        "preliminary_physics",
        "publication_ready"
      ]
    },
    "non_citation_required": {
      "type": "boolean"
    },
    "claimed_methodology": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "implemented_method_classification": {
      "enum": [
        "unconstrained_sampling",
        "constrained_search",
        "dispersive_derivation",
        "data_fit",
        "analytic_derivation",
        "hybrid"
      ]
    },
    "constraints_enforced": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disallowed_shortcuts_detected": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_pointers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_limitation": {
      "type": "boolean",
      "default": false
    },
    "human_signoff": {
      "type": "object",
      "required": [
        "reviewer",
        "verdict",
        "timestamp"
      ],
      "properties": {
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "enum": [
            "READY",
            "NOT_READY"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "const": "publication_ready"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "non_citation_required": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "enum": [
              "ecosystem_validation",
              "preliminary_physics"
            ]
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "non_citation_required": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implemented_method_classification": {
            "const": "unconstrained_sampling"
          }
        },
        "required": [
          "implemented_method_classification"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "constraints_enforced": {
                "minItems": 1
              }
            }
          },
          {
            "properties": {
              "expected_limitation": {
                "const": true
              }
            },
            "required": [
              "expected_limitation"
            ]
          }
        ]
      }
    }
  ],
  "additionalProperties": false
}
