{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "domain_pack_catalog_result_v1.schema.json",
  "title": "DomainPackCatalogResult v1",
  "description": "Read-only export of builtin domain-pack truth plus the current service runtime view.",
  "type": "object",
  "required": ["builtin_catalog", "runtime_catalog"],
  "properties": {
    "builtin_catalog": {
      "type": "object",
      "required": ["catalog_id", "pack_ids", "packs"],
      "properties": {
        "catalog_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "packs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["pack_id", "domain_prefixes", "description"],
            "properties": {
              "pack_id": {
                "type": "string",
                "minLength": 1
              },
              "domain_prefixes": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "runtime_catalog": {
      "type": "object",
      "required": ["catalog_id", "pack_ids", "packs"],
      "properties": {
        "catalog_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "packs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["pack_id", "domain_prefixes", "description"],
            "properties": {
              "pack_id": {
                "type": "string",
                "minLength": 1
              },
              "domain_prefixes": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
