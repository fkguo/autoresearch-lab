{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "distributor_event_v1.schema.json",
  "title": "DistributorEvent v1",
  "description": "One append-only Distributor decision event (one line in distributor_events_v1.jsonl).",
  "type": "object",
  "required": ["campaign_id", "step_id", "decision_id", "timestamp", "selected_action"],
  "properties": {
    "campaign_id": { "type": "string", "format": "uuid" },
    "step_id": { "type": "string", "format": "uuid" },
    "decision_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "policy_id": { "type": "string", "minLength": 1 },
    "factorization": { "enum": ["joint", "factorized"] },
    "budget_snapshot_ref": { "type": "string", "format": "uri" },
    "eligible_action_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "selected_action": {
      "type": "object",
      "required": ["backend_id", "operator_id", "island_id"],
      "properties": {
        "backend_id": { "type": "string", "minLength": 1 },
        "operator_id": { "type": "string", "minLength": 1 },
        "island_id": { "type": "string", "minLength": 1 },
        "team_policy_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "selection_probs": {
      "type": "object",
      "description": "Post-normalization probabilities used for sampling (keys are action IDs; values in [0,1]).",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "logits": {
      "type": "object",
      "description": "Optional pre-normalization scores/logits for audit (keys are action IDs).",
      "additionalProperties": { "type": "number" }
    },
    "rng_seed_used": { "type": "string" },
    "rng_alg": { "type": "string", "minLength": 1, "description": "Echo of the RNG algorithm used for this decision (for self-contained replay)." },
    "observed_reward": { "type": "number" },
    "realized_cost": {
      "type": "object",
      "description": "Optional realized costs (tokens/$/wallclock/etc.).",
      "additionalProperties": { "type": "number" }
    },
    "new_node_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "triggered_rules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "diagnostics": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": { "required": ["rng_seed_used"] },
      "then": { "required": ["rng_alg"] }
    }
  ],
  "additionalProperties": false
}
