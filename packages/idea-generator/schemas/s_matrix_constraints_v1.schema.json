{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "s_matrix_constraints_v1.schema.json",
  "title": "SMatrixConstraints v1",
  "description": "Machine-checkable constraints on an internal ππ partial-wave S-matrix variable S(s) used as input to full-PSD tightening (without outputting phase shifts). Constraints are provided on an s-grid in m_π^2 units. In idea-runs, validate-project binds this s-grid to the compute grid with an absolute tolerance |Δs|<=1e-12 (treated as an exact-match gate while avoiding JSON float round-trip false negatives). This assumes IEEE-754 binary64 JSON floats; truncating serialization (e.g., fewer digits) may fail the binding gate.",
  "type": "object",
  "required": [
    "version",
    "channel",
    "partial_wave",
    "s_units",
    "s_grid_mpi2",
    "constraints",
    "derivation_summary",
    "evidence_uris",
    "tags",
    "created_at_utc",
    "updated_at_utc"
  ],
  "properties": {
    "version": { "const": 1 },
    "channel": { "type": "string", "minLength": 1 },
    "partial_wave": {
      "type": "object",
      "required": ["I", "ell", "label"],
      "properties": {
        "I": { "type": "integer", "minimum": 0 },
        "ell": { "type": "integer", "minimum": 0 },
        "label": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "s_units": { "type": "string", "enum": ["mpi2"] },
    "s_grid_mpi2": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "number", "exclusiveMinimum": 0 },
      "description": "S-channel grid in units of m_pi^2. Gate semantics (idea-runs): must match the compute grid with |Δs|<=1e-12 (assumes IEEE-754 binary64 floats; truncating serialization may fail)."
    },
    "constraints": {
      "type": "object",
      "required": ["mode", "points"],
      "properties": {
        "mode": { "type": "string", "enum": ["box_disk", "halfspaces"] },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["s_mpi2"],
            "properties": {
              "s_mpi2": { "type": "number", "exclusiveMinimum": 0 },
              "re_min": { "type": "number" },
              "re_max": { "type": "number" },
              "im_min": { "type": "number" },
              "im_max": { "type": "number" },
              "disk_center_re": { "type": "number" },
              "disk_center_im": { "type": "number" },
              "disk_radius": { "type": "number", "minimum": 0 },
              "halfspaces": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["a_re", "b_im", "c"],
                  "properties": {
                    "a_re": { "type": "number" },
                    "b_im": { "type": "number" },
                    "c": { "type": "number" }
                  },
                  "additionalProperties": false
                }
              },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "applicability": {
          "type": "object",
          "properties": {
            "s_min_mpi2": { "type": "number", "exclusiveMinimum": 0 },
            "s_max_mpi2": { "type": "number", "exclusiveMinimum": 0 },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "derivation_summary": { "type": "string", "minLength": 1 },
    "evidence_uris": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri" }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "updated_at_utc": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
