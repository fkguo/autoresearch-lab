{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "idea_island_registry_v1.schema.json",
  "title": "IdeaIslandRegistry v1",
  "description": "Registry of islands for one campaign (machine-checkable). Points to per-island plan artifacts.",
  "type": "object",
  "required": ["version", "campaign_slug", "generated_at_utc", "islands"],
  "properties": {
    "version": { "const": 1 },
    "campaign_slug": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "islands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "island_id",
          "title",
          "status",
          "plan_artifact_path",
          "bootstrap_mechanism_tags",
          "tags",
          "last_updated_at_utc"
        ],
        "properties": {
          "island_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "status": { "enum": ["PLANNED", "IN_PROGRESS", "BLOCKED", "KILLED", "COMPLETED"] },
          "plan_artifact_path": {
            "type": "string",
            "minLength": 1,
            "description": "Project-relative path to the island's IdeaIslandPlan v1 JSON artifact."
          },
          "bootstrap_mechanism_tags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "last_updated_at_utc": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
