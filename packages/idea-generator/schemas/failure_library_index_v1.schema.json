{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "failure_library_index_v1.schema.json",
  "title": "FailureLibraryIndex v1",
  "description": "Aggregated index over failed_approach_v1 JSONL records across projects (idea-runs monorepo).",
  "type": "object",
  "required": ["version", "generated_at_utc", "entries", "stats"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["project_slug", "artifact_relpath", "line_number", "failed_approach"],
        "properties": {
          "project_slug": { "type": "string", "minLength": 1 },
          "artifact_relpath": { "type": "string", "minLength": 1 },
          "line_number": { "type": "integer", "minimum": 1 },
          "failed_approach": { "$ref": "./failed_approach_v1.schema.json" }
        },
        "additionalProperties": false
      }
    },
    "stats": {
      "type": "object",
      "required": ["projects_scanned", "entries_total"],
      "properties": {
        "projects_scanned": { "type": "integer", "minimum": 0 },
        "entries_total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
