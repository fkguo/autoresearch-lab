{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "numerics_method_selection_v1.schema.json",
  "title": "NumericsMethodSelection v1",
  "description": "Records candidate numerical methods and rationale for chosen implementation.",
  "type": "object",
  "required": [
    "generated_at",
    "scope",
    "non_citation_required",
    "problem_class",
    "options_considered",
    "chosen_method",
    "chosen_is_simplest",
    "rejection_reasons",
    "implementation_plan"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "enum": [
        "ecosystem_validation",
        "preliminary_physics",
        "publication_ready"
      ]
    },
    "non_citation_required": {
      "type": "boolean"
    },
    "problem_class": {
      "enum": [
        "quadrature",
        "ode",
        "optimization",
        "sampling",
        "linear_algebra",
        "other"
      ]
    },
    "options_considered": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "method_name",
          "method_family",
          "complexity_tier",
          "error_control"
        ],
        "properties": {
          "method_name": {
            "type": "string",
            "minLength": 1
          },
          "method_family": {
            "type": "string",
            "minLength": 1
          },
          "complexity_tier": {
            "enum": [
              "baseline",
              "intermediate",
              "advanced"
            ]
          },
          "error_control": {
            "enum": [
              "none",
              "heuristic",
              "rigorous"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "chosen_method": {
      "type": "string",
      "minLength": 1
    },
    "chosen_is_simplest": {
      "type": "boolean"
    },
    "justification_if_simplest": {
      "type": "string",
      "minLength": 20
    },
    "rejection_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "implementation_plan": {
      "type": "object",
      "required": [
        "libraries",
        "key_parameters",
        "stability_risks"
      ],
      "properties": {
        "libraries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "key_parameters": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean"
            ]
          }
        },
        "stability_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "const": "publication_ready"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "non_citation_required": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "enum": [
              "ecosystem_validation",
              "preliminary_physics"
            ]
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "non_citation_required": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "enum": [
              "preliminary_physics",
              "publication_ready"
            ]
          },
          "chosen_is_simplest": {
            "const": true
          }
        },
        "required": [
          "scope",
          "chosen_is_simplest"
        ]
      },
      "then": {
        "required": [
          "justification_if_simplest"
        ]
      }
    }
  ],
  "additionalProperties": false
}
