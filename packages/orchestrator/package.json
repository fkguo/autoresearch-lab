{
  "name": "@autoresearch/orchestrator",
  "version": "0.0.1",
  "private": true,
  "description": "Generic lifecycle control plane and bounded workflow CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "autoresearch": "dist/cli.js"
  },
  "scripts": {
    "prebuild": "node ../../scripts/ensure-workspace-package-artifacts.mjs @autoresearch/shared @autoresearch/literature-workflows @autoresearch/rep-sdk",
    "build": "tsc --build",
    "pretest": "node ../../scripts/ensure-workspace-package-artifacts.mjs @autoresearch/shared @autoresearch/literature-workflows @autoresearch/rep-sdk",
    "test": "vitest run",
    "lint": "echo \"no lint yet\"",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@autoresearch/literature-workflows": "workspace:^",
    "@autoresearch/rep-sdk": "workspace:^",
    "@autoresearch/shared": "workspace:^",
    "ajv": "^8.18.0",
    "zod": "^4.3.5"
  }
}
