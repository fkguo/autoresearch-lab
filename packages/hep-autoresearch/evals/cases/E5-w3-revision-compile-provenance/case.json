{
  "schema_version": 1,
  "case_id": "E5-w3-revision-compile-provenance",
  "workflow": "W3_revision",
  "description": "W3 revision: paper compiles and provenance table is populated (demo run artifacts).",
  "inputs": {
    "tag": "M2-w3-rev-devcheck-r1",
    "paper_root": "paper"
  },
  "acceptance": {
    "required_paths_exist": [
      "scripts/run_w3_revision.py",
      "src/hep_autoresearch/toolkit/w3_revision.py",
      "paper/main.tex",
      "artifacts/runs/M2-w3-rev-devcheck-r1/revision/manifest.json",
      "artifacts/runs/M2-w3-rev-devcheck-r1/revision/summary.json",
      "artifacts/runs/M2-w3-rev-devcheck-r1/revision/analysis.json"
    ],
    "json_numeric_checks": [
      {
        "path": "artifacts/runs/M2-w3-rev-devcheck-r1/revision/analysis.json",
        "pointer": "#/results/compile_exit_code_before",
        "max_abs": 0
      },
      {
        "path": "artifacts/runs/M2-w3-rev-devcheck-r1/revision/analysis.json",
        "pointer": "#/results/compile_exit_code_after",
        "max_abs": 0
      },
      {
        "path": "artifacts/runs/M2-w3-rev-devcheck-r1/revision/analysis.json",
        "pointer": "#/results/provenance_rows",
        "min": 1
      }
    ]
  },
  "notes": "This is a deterministic compile+provenance regression anchor. It does not run external LLMs."
}
