      "artifacts/runs/M54-project-init-r1/orchestrator_regression/project_init_project/knowledge_base/_index/kb_profiles/curated.json",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/project_init_project/artifacts/runs/M54-project-init-r1-proj-reproduce/approvals/A3-0001/packet.md",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/project_init_project/artifacts/runs/M54-project-init-r1-proj-reproduce/kb_profile/kb_profile.json"
    ],
    "json_numeric_checks": [
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/init_exit_code",
        "min": 0,
        "max": 0
      },
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/status_subdir_exit_code",
        "min": 0,
        "max": 0
      },
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/nested_init_exit_code",
        "min": 2,
        "max": 2
      },
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/nested_init_allow_exit_code",
        "min": 0,
        "max": 0
      },
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/gate_exit_code",
        "min": 3,
        "max": 3
      }
    ],
    "json_value_checks": [
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/status_subdir_state_path_ok",
        "type": "boolean",
        "equals": true
      },
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/pending_category",
        "type": "string",
        "equals": "A3"
      },
      {
        "path": "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/project_init/nested_state_json_exists",
        "type": "boolean",
        "equals": true
      }
    ]
  },
  "notes": "Run first: python3 scripts/run_orchestrator_regression.py --tag M54-project-init-r1 --scenarios project_init."
}
