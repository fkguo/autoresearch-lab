{
  "schema_version": 1,
  "case_id": "E30-project-init-scaffold-v0",
  "workflow": "custom",
  "description": "Regression: hep-autoresearch init scaffolds a real research project root (docs+KB+specs) and root discovery works from subdirs; a run can reach the A3 gate without schema/KB failures.",
  "inputs": {
    "tag": "M54-project-init-r1"
  },
  "acceptance": {
    "required_paths_exist": [
      "src/hep_autoresearch/toolkit/project_scaffold.py",
      "src/hep_autoresearch/orchestrator_cli.py",
      "src/hep_autoresearch/toolkit/orchestrator_regression.py",
      "scripts/run_orchestrator_regression.py",
      "specs/plan.schema.json",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/manifest.json",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/summary.json",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/analysis.json",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/project_init_project/.autoresearch/state.json",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/project_init_project/.autoresearch/approval_policy.json",
      "artifacts/runs/M54-project-init-r1/orchestrator_regression/project_init_project/.autoresearch/plan.md",
