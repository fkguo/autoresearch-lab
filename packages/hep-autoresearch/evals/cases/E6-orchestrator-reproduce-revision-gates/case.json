{
  "schema_version": 1,
  "case_id": "E6-orchestrator-reproduce-revision-gates",
  "workflow": "custom",
  "description": "Orchestrator regression: reproduce/revision auto-gates (A3/A4) trigger awaiting_approval (exit=3), produce approval packets, then complete after approve (exit=0).",
  "inputs": {
    "tag": "M4-orch-reg-r1"
  },
  "acceptance": {
    "required_paths_exist": [
      "scripts/run_orchestrator_regression.py",
      "src/hep_autoresearch/toolkit/orchestrator_regression.py",
      "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/manifest.json",
      "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/summary.json",
      "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
      "artifacts/runs/M4-orch-reg-r1-reproduce/approvals/A3-0001/packet.md",
      "artifacts/runs/M4-orch-reg-r1-reproduce/context/context.md",
      "artifacts/runs/M4-orch-reg-r1-reproduce/context/context.json",
      "artifacts/runs/M4-orch-reg-r1-reproduce/reproduce/manifest.json",
      "artifacts/runs/M4-orch-reg-r1-reproduce/reproduce/summary.json",
      "artifacts/runs/M4-orch-reg-r1-reproduce/reproduce/analysis.json",
      "artifacts/runs/M4-orch-reg-r1-revision/approvals/A4-0001/packet.md",
      "artifacts/runs/M4-orch-reg-r1-revision/context/context.md",
      "artifacts/runs/M4-orch-reg-r1-revision/context/context.json",
      "artifacts/runs/M4-orch-reg-r1-revision/revision/manifest.json",
      "artifacts/runs/M4-orch-reg-r1-revision/revision/summary.json",
      "artifacts/runs/M4-orch-reg-r1-revision/revision/analysis.json"
    ],
    "reading_note_required_fields": [
      "Context pack:"
    ],
    "json_numeric_checks": [
      {
        "path": "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/orchestrator_init_exit_code",
        "max_abs": 0
      },
      {
        "path": "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/reproduce/gate_exit_code",
        "min": 3,
        "max": 3
      },
      {
        "path": "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/reproduce/approve_exit_code",
        "max_abs": 0
      },
      {
        "path": "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/reproduce/final_exit_code",
        "max_abs": 0
      },
      {
        "path": "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/revision/gate_exit_code",
        "min": 3,
        "max": 3
      },
      {
        "path": "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/revision/approve_exit_code",
        "max_abs": 0
      },
      {
        "path": "artifacts/runs/M4-orch-reg-r1/orchestrator_regression/analysis.json",
        "pointer": "#/results/revision/final_exit_code",
        "max_abs": 0
      }
    ]
  },
  "notes": "This regression anchor runs locally and does not call external LLMs."
}
