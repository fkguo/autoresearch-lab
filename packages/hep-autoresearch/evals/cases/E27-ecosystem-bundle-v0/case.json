        "equals": false
      },
      {
        "path": "artifacts/runs/M48-t37-r1/ecosystem_bundle/analysis.json",
        "pointer": "#/results/bootstrap_smoke/ok_rc",
        "type": "integer",
        "equals": 0
      },
      {
        "path": "artifacts/runs/M48-t37-r1/ecosystem_bundle/analysis.json",
        "pointer": "#/results/bootstrap_smoke/bad_expected_nonzero",
        "type": "boolean",
        "equals": true
      }
    ],
    "json_numeric_checks": [
      {
        "path": "artifacts/runs/M48-t37-r1/ecosystem_bundle/analysis.json",
        "pointer": "#/results/bundle/bytes",
