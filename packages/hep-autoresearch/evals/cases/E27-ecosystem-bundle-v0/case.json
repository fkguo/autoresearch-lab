          "hep-autoresearch-ecosystem-bundle-v0/components/hep-autoresearch/pyproject.toml",
          "hep-autoresearch-ecosystem-bundle-v0/components/hep-research-mcp/packages/hep-research-mcp/dist/index.js",
          "hep-autoresearch-ecosystem-bundle-v0/components/skills/review-swarm/SKILL.md"
        ]
      }
    ]
  },
  "notes": "Run first: python3 scripts/run_ecosystem_bundle.py --tag M48-t37-r1. Then: python3 scripts/run_evals.py --case-id E27-ecosystem-bundle-v0 --tag M48-t37-eval-r1."
