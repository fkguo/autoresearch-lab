      "artifacts/runs/M48-t37-r1/ecosystem_bundle/analysis.json",
      "artifacts/runs/M48-t37-r1/ecosystem_bundle/report.md",
      "artifacts/runs/M48-t37-r1/ecosystem_bundle/bundle_manifest.json",
      "artifacts/runs/M48-t37-r1/ecosystem_bundle/core_bundle.zip"
    ],
    "json_value_checks": [
      {
        "path": "artifacts/runs/M48-t37-r1/ecosystem_bundle/analysis.json",
        "pointer": "#/results/ok",
        "type": "boolean",
        "equals": true
      },
      {
        "path": "artifacts/runs/M48-t37-r1/ecosystem_bundle/analysis.json",
