{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reviewer Summary (structured-only)",
  "type": "object",
  "required": ["artifacts_produced", "acceptance_criteria_status", "anomalies", "limitations"],
  "properties": {
    "artifacts_produced": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "List of artifact paths produced in this step/run."
    },
    "acceptance_criteria_status": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "status", "evidence_pointer"],
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["met", "not_met", "unclear"] },
          "evidence_pointer": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "description": "Per-criterion status with evidence pointer (artifact pointer or diff pointer)."
    },
    "anomalies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Any anomalies detected during execution or review."
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Limitations encountered (missing info, unstable numerics, ambiguous assumptions, etc.)."
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["approval_id", "action_kind", "decision"],
        "properties": {
          "approval_id": { "type": "string" },
          "action_kind": { "type": "string" },
          "decision": { "type": "string", "enum": ["approved", "rejected", "skipped"] }
        },
        "additionalProperties": false
      }
    }
    ,
    "cost_stats": {
      "type": "object",
      "required": ["tokens_in", "tokens_out"],
      "properties": {
        "tokens_in": { "type": "integer", "minimum": 0 },
        "tokens_out": { "type": "integer", "minimum": 0 },
        "usd_estimate": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false,
      "description": "Optional: cost/usage accounting for this run (best-effort)."
    }
  },
  "additionalProperties": false
}
