{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eval Case",
  "type": "object",
  "required": ["schema_version", "case_id", "workflow", "inputs", "acceptance"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "workflow": {
      "type": "string",
      "enum": [
        "ingest",
        "reproduce",
        "computation",
        "draft",
        "revision",
        "paper_reviser",
        "derivation_check",
        "custom"
      ]
    },
    "description": { "type": "string" },
    "inputs": { "type": "object" },
    "acceptance": { "type": "object" },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
