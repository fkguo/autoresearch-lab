{
  "schema_version": 2,
  "run_id": "M65-a5-schrodinger-ho-r2",
  "workflow_id": "computation",
  "title": "Schrodinger HO ground state (ODE) + analytical validation",

  "parameters": {
    "omega": {"type": "number", "default": 1.0, "description": "HO frequency (natural units)"},
    "x_max": {"type": "number", "default": 3.0, "description": "Max x for integration (kept small to avoid exciting the growing-mode numerically)"},
    "n_grid": {"type": "integer", "default": 2001, "description": "Grid points on [0, x_max]"}
  },

  "on_failure": "fail-fast",

  "phases": [
    {
      "phase_id": "derive_params",
      "description": "Derive E=omega/2 (ground state) and record parameters",
      "backend": {
        "kind": "shell",
        "argv": ["python3", "scripts/derive_params.py", "--omega", "${omega}"],
        "cwd": ".",
        "timeout_seconds": 30
      },
      "outputs": ["results/params.json"],
      "retries": 0
    },
    {
      "phase_id": "solve_numerics",
      "description": "Solve psi'' = (omega^2 x^2 - 2E) psi by deterministic RK4; psi(0)=1, psi'(0)=0",
      "depends_on": ["derive_params"],
      "backend": {
        "kind": "shell",
        "argv": [
          "python3",
          "scripts/solve_numerics.py",
          "--params",
          "phases/derive_params/results/params.json",
          "--x-max",
          "${x_max}",
          "--n-grid",
          "${n_grid}"
        ],
        "cwd": ".",
        "timeout_seconds": 60
      },
      "outputs": ["results/wavefunction.json", "results/numerics_report.json"],
      "retries": 0
    },
    {
      "phase_id": "validate",
      "description": "Compare against psi_analytic(x)=exp(-omega x^2/2) (unnormalized, psi(0)=1); compute RMSE and max abs diff",
      "depends_on": ["solve_numerics", "derive_params"],
      "backend": {
        "kind": "shell",
        "argv": [
          "python3",
          "scripts/validate.py",
          "--wavefunction",
          "phases/solve_numerics/results/wavefunction.json",
          "--params",
          "phases/derive_params/results/params.json"
        ],
        "cwd": ".",
        "timeout_seconds": 30
      },
      "outputs": ["results/validation_report.json"],
      "retries": 0
    }
  ],

  "headline_numbers": {
    "source": "phases/validate/results/validation_report.json",
    "extract": [
      {"pointer": "#/rmse", "label": "RMSE (psi_num vs psi_analytic)", "tier": "T1"},
      {"pointer": "#/max_abs_diff", "label": "Max abs diff", "tier": "T2"},
      {"pointer": "#/psi_at_x_max", "label": "psi(x_max) numeric", "tier": "T3"}
    ]
  },

  "acceptance": {
    "json_numeric_checks": [
      {"path": "phases/validate/results/validation_report.json", "pointer": "#/rmse", "max": 1e-8},
      {"path": "phases/validate/results/validation_report.json", "pointer": "#/max_abs_diff", "max": 1e-8},
      {"path": "phases/validate/results/validation_report.json", "pointer": "#/psi0_abs_err", "max": 1e-12}
    ]
  }
}
