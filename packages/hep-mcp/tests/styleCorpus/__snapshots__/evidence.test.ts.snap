exports[`StyleCorpus LaTeX→evidence (R3) > extracts macro-wrapped equations and prevents paragraph leakage 1`] = `
[
  {
    "env": "equation",
    "equation_type": "display",
    "label": "eq:test",
    "text": "a = b",
  },
  {
    "env": "eqnarray*",
    "equation_type": "eqnarray",
    "label": undefined,
    "text": "x &=& y",
  },
]
`;
