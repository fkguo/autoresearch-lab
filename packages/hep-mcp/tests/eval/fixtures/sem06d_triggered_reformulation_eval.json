{
  "name": "sem06d_triggered_reformulation",
  "version": 1,
  "description": "Triggered reformulation + QPP on top of the SEM-06b discovery backbone",
  "module": "NEW-SEM-06d",
  "cases": [
    {
      "id": "doi-known-item-no-trigger",
      "tags": ["known_item", "exact_id", "easy_query"],
      "input": {
        "query": "10.1000/exact-known-item",
        "intent": "known_item",
        "providers": {
          "original": {
            "inspire": [
              { "title": "Exact known-item retrieval across providers", "identifiers": { "doi": "10.1000/exact-known-item", "recid": "1001", "arxiv_id": "2501.00001" }, "authors": ["A. Exact"], "year": 2025, "citation_count": 12 }
            ],
            "openalex": [
              { "title": "Exact known-item retrieval across providers", "identifiers": { "doi": "10.1000/exact-known-item", "openalex_id": "W1001" }, "authors": ["A. Exact"], "year": 2025, "citation_count": 24 }
            ],
            "arxiv": [
              { "title": "Exact known-item retrieval across providers", "identifiers": { "doi": "10.1000/exact-known-item", "arxiv_id": "2501.00001" }, "authors": ["A. Exact"], "year": 2025, "citation_count": 8 }
            ]
          }
        },
        "rerank": {
          "mode": "applied",
          "ranked_keys": ["paper:doi:10.1000/exact-known-item"]
        }
      },
      "expected": {
        "gold_canonical_key": "paper:doi:10.1000/exact-known-item",
        "provider_hit_providers": ["inspire", "openalex", "arxiv"],
        "canonical_count": 1,
        "expected_trigger_decision": "not_triggered",
        "expected_qpp_status": "applied",
        "expected_reformulation_status": "not_triggered",
        "expected_effective_query": "10.1000/exact-known-item",
        "expected_rerank_status": "insufficient_candidates",
        "max_final_rank": 1,
        "expected_sampling_calls": 0
      }
    },
