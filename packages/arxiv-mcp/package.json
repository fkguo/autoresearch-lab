{
  "name": "@autoresearch/arxiv-mcp",
  "version": "0.1.0",
  "description": "Domain-agnostic arXiv MCP server for paper search, metadata, and source content access",
  "author": "Feng-Kun Guo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tooling": {
      "import": "./dist/tooling.js",
      "types": "./dist/tooling.d.ts"
    }
  },
  "bin": {
    "arxiv-mcp": "./bin/arxiv-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@autoresearch/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "tar": "^7.4.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.16"
  }
}
