{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meta/schemas/paper_manifest_v2.schema.json",
  "title": "Paper Manifest v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "version",
    "parent_version",
    "review_ref"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "parent_version": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "review_ref": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
