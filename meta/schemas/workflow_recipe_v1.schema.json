{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meta/schemas/workflow_recipe_v1.schema.json",
  "title": "Workflow Recipe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recipe_id",
    "name",
    "description",
    "entry_tool",
    "steps"
  ],
  "properties": {
    "recipe_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entry_tool": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "purpose"
        ],
        "anyOf": [
          {
            "required": [
              "tool"
            ]
          },
          {
            "required": [
              "action"
            ]
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "discover.seed_search",
              "analyze.topic_evolution",
              "analyze.citation_network",
              "analyze.paper_connections",
              "analyze.provenance_trace",
              "analyze.paper_set_critical_review",
              "materialize.evidence_build"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "supports_keyword_search",
                "supports_semantic_search",
                "supports_citation_graph",
                "supports_fulltext",
                "supports_source_download",
                "supports_open_access_content",
                "analysis.topic_evolution",
                "analysis.citation_network",
                "analysis.paper_set_connections",
                "analysis.provenance_trace",
                "analysis.paper_set_critical_review"
              ]
            }
          },
          "preferred_providers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "inspire",
                "openalex",
                "arxiv",
                "zotero",
                "crossref",
                "datacite",
                "github",
                "doi"
              ]
            }
          },
          "degrade_mode": {
            "type": "string",
            "enum": [
              "fail_closed",
              "skip_with_reason",
              "partial_result"
            ]
          },
          "consumer_hints": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "phases": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "project_required": {
                "type": "boolean"
              },
              "run_required": {
                "type": "boolean"
              }
            }
          },
          "params": {
            "type": "object",
            "default": {}
          }
        }
      }
    }
  }
}
