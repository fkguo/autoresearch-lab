{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meta/schemas/workflow_recipe_v1.schema.json",
  "title": "Workflow Recipe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recipe_id",
    "name",
    "description",
    "entry_tool",
    "steps"
  ],
  "properties": {
    "recipe_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entry_tool": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "tool",
          "purpose"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "params": {
            "type": "object",
            "default": {}
          }
        }
      }
    }
  }
}
