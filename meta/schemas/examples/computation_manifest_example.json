{
  "schema_version": 1,
  "title": "One-loop scalar integral computation (example)",
  "description": "Compute one-loop scalar integrals for a 2→2 scattering process using FeynCalc + LoopTools, then validate against analytic results in Python.",
  "entry_point": {
    "script": "mathematica/run_all.wl",
    "tool": "mathematica",
    "args": [],
    "env": {
      "LOOPTOOLS_DIR": "/usr/local/LoopTools-2.15"
    }
  },
  "steps": [
    {
      "id": "generate_diagrams",
      "description": "Generate Feynman diagrams with FeynArts and compute amplitudes with FeynCalc",
      "tool": "mathematica",
      "script": "mathematica/01_generate_diagrams.wl",
      "args": [],
      "expected_outputs": ["outputs/amplitudes.m", "outputs/diagrams.pdf"],
      "depends_on": [],
      "timeout_minutes": 30
    },
    {
      "id": "evaluate_loop_integrals",
      "description": "Numerically evaluate loop integrals via LoopTools at benchmark phase-space points",
      "tool": "mathematica",
      "script": "mathematica/02_loop_integrals.wl",
      "args": ["--points", "configs/phase_space_points.json"],
      "expected_outputs": ["outputs/loop_results.csv"],
      "depends_on": ["generate_diagrams"],
      "timeout_minutes": 60
    },
    {
      "id": "validate_results",
      "description": "Cross-check numerical loop results against analytic reference values",
      "tool": "python",
      "script": "python/validate.py",
      "args": ["--input", "outputs/loop_results.csv", "--reference", "configs/reference_values.json"],
      "expected_outputs": ["outputs/validation_report.json"],
      "depends_on": ["evaluate_loop_integrals"],
      "timeout_minutes": 5
    }
  ],
  "environment": {
    "mathematica_version": "13.3",
    "python_version": "3.11",
    "platform": "any",
    "notes": "Tested on macOS 14 and Ubuntu 22.04. Requires LoopTools shared library in LOOPTOOLS_DIR."
  },
  "dependencies": {
    "mathematica_packages": ["FeynCalc", "FeynArts", "LoopTools"],
    "python_packages": ["numpy>=1.24", "scipy>=1.11"],
    "external_libraries": ["LoopTools-2.15"],
    "data_files": ["configs/phase_space_points.json", "configs/reference_values.json"]
  },
  "computation_budget": {
    "estimated_runtime_minutes": 90,
    "max_runtime_minutes": 180,
    "max_memory_gb": 8.0,
    "max_cpu_cores": 4,
    "max_disk_gb": 2.0
  },
  "outputs": [
    "outputs/amplitudes.m",
    "outputs/loop_results.csv",
    "outputs/validation_report.json",
    "outputs/diagrams.pdf"
  ],
  "created_at": "2026-02-27T00:00:00Z"
}
