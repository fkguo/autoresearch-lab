{
  "version": 1,
  "note": "Classification and docs/tests consumption layer only. `autoresearch` stays the stateful CLI front door, `orch_*` stays the control-plane MCP/operator counterpart, and provider surfaces stay bounded atomic MCP operators. Exact inventories remain owned by their source surfaces and must be kept in sync by fail-closed tests.",
  "surfaces": {
    "autoresearch_cli": {
      "classification": "canonical_public",
      "surface_kind": "cli_command_inventory",
      "owner": "@autoresearch/orchestrator",
      "notes": [
        "Canonical stateful CLI front door for initialized external project roots.",
        "Owns lifecycle state, workflow-plan, bounded execution, verification, higher-conclusion gating, and proposal decisions."
      ],
      "exact_inventory_source": "packages/orchestrator/src/cli-command-inventory.ts",
      "commands": [
        {
          "command": "init",
          "usage": "autoresearch init [options]"
        },
        {
          "command": "run",
          "usage": "autoresearch run --workflow-id <id> [options]"
        },
        {
          "command": "verify",
          "usage": "autoresearch verify --run-id <id> --status <passed|failed|blocked> --summary \"...\" --evidence-path <path> [--evidence-path <path> ...]"
        },
        {
          "command": "final-conclusions",
          "usage": "autoresearch final-conclusions --run-id <id> [--note \"...\"]"
        },
        {
          "command": "proposal-decision",
          "usage": "autoresearch proposal-decision --proposal-kind <repair|skill|optimize|innovate> --proposal-id <id> --decision <accepted_for_later|dismissed|already_captured> [--note \"...\"]"
        },
        {
          "command": "status",
          "usage": "autoresearch status [--json]"
        },
        {
          "command": "approve",
          "usage": "autoresearch approve <approval_id> [--note \"...\"]"
        },
        {
          "command": "pause",
          "usage": "autoresearch pause [--note \"...\"]"
        },
        {
          "command": "resume",
          "usage": "autoresearch resume [--note \"...\"] [--force]"
        },
        {
          "command": "export",
          "usage": "autoresearch export [options]"
        },
        {
          "command": "workflow-plan",
          "usage": "autoresearch workflow-plan --recipe <recipe_id> [options]"
        }
      ]
    },
    "hep_autoresearch_internal_parser": {
      "classification": "internal_only",
      "surface_kind": "internal_full_parser",
      "owner": "packages/hep-autoresearch",
      "notes": [
        "Maintainer/source-run compatibility residue only; not a normal front door for fresh external projects.",
        "Public lifecycle and workflow front doors remain rooted at `autoresearch`."
      ],
      "exact_inventory_source": "packages/hep-autoresearch/src/hep_autoresearch/orchestrator_cli.py#main",
      "command_groups": [
        {
          "group": "legacy_lifecycle_adapters",
          "commands": [
            "init",
            "status",
            "pause",
            "resume",
            "approve",
            "export"
          ]
        },
        {
          "group": "internal_support_commands",
          "commands": [
            "branch"
          ]
        },
        {
          "group": "retired_public_support_commands",
          "commands": [
            "method-design",
            "run-card"
          ]
        },
        {
          "group": "internal_workflow_paths",
          "commands": [
            "run --workflow-id computation",
            "run --workflow-id ingest",
            "run --workflow-id paper_reviser",
            "run --workflow-id reproduce",
            "run --workflow-id revision",
            "run --workflow-id literature_survey_polish"
          ]
        },
        {
          "group": "internal_adapter_workflow_paths",
          "commands": [
            "run --workflow-id shell_adapter_smoke"
          ]
        }
      ]
    },
    "orchestrator_mcp_tools_spec": {
      "classification": "canonical_public",
      "surface_kind": "exact_doc_inventory",
      "owner": "@autoresearch/orchestrator",
      "notes": [
        "Canonical MCP/operator counterpart of the same control plane surfaced by `autoresearch`.",
        "Not a competing root product identity and not a provider-local workflow shell."
      ],
      "exact_inventory_source": "meta/docs/orchestrator-mcp-tools-spec.md",
      "live_registry_source": "packages/orchestrator/src/orch-tools/index.ts / @autoresearch/orchestrator exported ORCH_TOOL_SPECS",
      "namespace_families": [
        "orch_run_*",
        "orch_policy_*",
        "orch_fleet_*"
      ]
    },
    "idea_mcp": {
      "classification": "canonical_public",
      "surface_kind": "mcp_tool_inventory",
      "owner": "@autoresearch/idea-mcp",
      "notes": [
        "Experimental runtime bridge for idea search/eval loops.",
        "Not a root front door and intentionally narrower than the full `idea-engine` runtime contract."
      ],
      "exact_inventory_source": "packages/idea-mcp/src/tool-registry.ts",
      "tools": [
        {
          "name": "idea_campaign_init",
          "rpc_method": "campaign.init"
        },
        {
          "name": "idea_campaign_status",
          "rpc_method": "campaign.status"
        },
        {
          "name": "idea_campaign_topup",
          "rpc_method": "campaign.topup"
        },
        {
          "name": "idea_campaign_pause",
          "rpc_method": "campaign.pause"
        },
        {
          "name": "idea_campaign_resume",
          "rpc_method": "campaign.resume"
        },
        {
          "name": "idea_campaign_complete",
          "rpc_method": "campaign.complete"
        },
        {
          "name": "idea_search_step",
          "rpc_method": "search.step"
        },
        {
          "name": "idea_eval_run",
          "rpc_method": "eval.run"
        }
      ]
    }
  }
}
